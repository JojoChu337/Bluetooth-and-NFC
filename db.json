{
  "intro": {
    "html": "<div class=\"p-5 text-center bg-body-tertiary rounded-4 border\"><h1 class=\"text-primary\"><i class=\"fas fa-network-wired me-2\"></i>Willkommen im Network Designer</h1><p class=\"lead mt-3\">Nutze die Navigation oben, um das Signaltool zu starten und die Bluetooth- bzw. NFC-Simulation auszutesten!</p></div>"
  },
  "bluetooth": {
    "html": "<div class=\"p-3 rounded-4 border shadow-sm\"><h2 class=\"mb-4 text-primary\">Network Designer 6.1</h2><p class=\"lead text-body-secondary\">32-Meter-Feld | Whiteboard Edition</p><div class=\"row mb-3 g-2 p-3 rounded-4 bg-body-tertiary border border-secondary-subtle\"><div class=\"col-md-3\"><label class=\"form-label small fw-bold text-body\">Verbindung</label><select id=\"target-select\" class=\"form-select form-select-sm bg-body text-body border-secondary\" onchange=\"setPairing(this.value)\"><option value=\"null\">Ausgeschaltet</option><option value=\"bt\">Bluetooth Box</option><option value=\"nfc\">NFC Tag</option></select></div><div class=\"col-md-3\"><label class=\"form-label small fw-bold text-body\">Wand-Material</label><select id=\"wall-material\" class=\"form-select form-select-sm bg-body text-body border-secondary\" onchange=\"updateWallStyle()\"><option value=\"none\">Keine Wand</option><option value=\"wood\">Holz (Maserung)</option><option value=\"concrete\" selected>Beton (Massiv)</option><option value=\"metal\">Metall (Eisen)</option></select></div><div class=\"col-md-3\"><label class=\"form-label small fw-bold text-body\">Umgebung</label><select id=\"env-select\" class=\"form-select form-select-sm bg-body text-body border-secondary\" onchange=\"updateSim()\"><option value=\"1\">Vakuum</option><option value=\"0.7\" selected>Büro</option></select></div><div class=\"col-md-3\"><label class=\"form-label small fw-bold text-body\">Handy-Typ</label><select id=\"bt-version\" class=\"form-select form-select-sm bg-body text-body border-secondary\" onchange=\"updateSim()\"><option value=\"4.0\">Legacy (4.0)</option><option value=\"5.0\" selected>Modern (5.0)</option></select></div></div><div id=\"sandbox\" style=\"position: relative; height: 400px; background: #f8f9fa; border-radius: 12px; border: 2px solid #dee2e6; overflow: hidden; touch-action: none;\"><div style=\"position: absolute; bottom: 15px; right: 15px; background: rgba(255,255,255,0.9); color: #334155; padding: 4px 12px; border-radius: 6px; font-size: 11px; z-index: 20; border: 1px solid #cbd5e1;\"><div style=\"width: 150px; border-bottom: 2px solid #334155; margin-bottom: 3px;\"></div> 5 Meter</div><svg id=\"connection-svg\" style=\"position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 5;\"><line id=\"sig-line\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"0\" stroke=\"#0d6efd\" stroke-width=\"3\" stroke-dasharray=\"8,4\" opacity=\"0\" /></svg><div id=\"wall\" class=\"draggable-node\" style=\"position: absolute; left: 200px; top: 100px; width: 30px; height: 180px; border-radius: 4px; cursor: move; z-index: 10; box-shadow: 0 4px 6px rgba(0,0,0,0.1);\"><div id=\"wall-label\" style=\"font-size: 10px; color: white; transform: rotate(90deg); margin-top: 80px; text-align: center; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);\">BETON</div></div><div id=\"node-bt\" class=\"draggable-node text-center\" style=\"position: absolute; left: 350px; top: 40px; width: 60px; cursor: move; z-index: 10;\"><i class=\"fas fa-scissors\" style=\"font-size: 30px; color: #0d6efd;\"></i><div id=\"bt-dist\" class=\"fw-bold mt-1\" style=\"font-size: 12px; color: #334155;\">0m</div></div><div id=\"node-nfc\" class=\"draggable-node text-center\" style=\"position: absolute; left: 40px; top: 40px; width: 60px; cursor: move; z-index: 10;\"><i class=\"fab fa-nfc-symbol\" style=\"font-size: 30px; color: #198754;\"></i><div id=\"nfc-dist\" class=\"fw-bold mt-1\" style=\"font-size: 12px; color: #334155;\">0m</div></div><div id=\"node-jammer\" class=\"draggable-node text-center\" style=\"position: absolute; left: 50px; top: 280px; width: 60px; cursor: move; z-index: 10;\"><i class=\"fas fa-radiation-alt\" style=\"font-size: 25px; color: #dc3545;\"></i><div style=\"font-size: 9px; color: #dc3545; font-weight: bold;\">STÖRER</div></div><div id=\"node-booster\" class=\"draggable-node text-center\" style=\"position: absolute; left: 350px; top: 280px; width: 60px; cursor: move; z-index: 10;\"><i class=\"fas fa-rocket\" style=\"font-size: 25px; color: #f59e0b;\"></i><div style=\"font-size: 9px; color: #f59e0b; font-weight: bold;\">BOOSTER</div></div><div id=\"phone\" class=\"draggable-node\" style=\"position: absolute; left: 180px; top: 300px; width: 50px; cursor: move; z-index: 100;\"><div style=\"background: #334155; border-radius: 10px; height: 85px; border: 2px solid #0d6efd; padding: 5px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);\"><div id=\"phone-ui\" style=\"background: #000; height: 100%; border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;\"><div id=\"p-label\" style=\"font-size: 9px; color: #0d6efd; font-weight: bold;\">OFF</div><div id=\"p-val\" style=\"color: #fff; font-size: 11px;\"></div></div></div></div></div><div class=\"mt-3 p-3 rounded-4 bg-body-secondary border border-secondary-subtle shadow-sm\"><div class=\"row small text-body\"><div class=\"col-md-6 border-md-end border-secondary-subtle\"><h6 class=\"fw-bold text-primary\"><i class=\"fas fa-info-circle me-1\"></i> Status-Check</h6><p class=\"mb-1\"><strong>dBm-Wert:</strong> Signalstärke. -30 (top) bis -90 (Abbruch).</p><p class=\"mb-0\"><strong>Wand:</strong> Metall blockiert Wellen fast vollständig.</p></div><div class=\"col-md-6 ps-md-3 mt-3 mt-md-0\"><h6 class=\"fw-bold text-warning\"><i class=\"fas fa-bolt me-1\"></i> Einflüsse</h6><p class=\"mb-1\"><strong>Störer:</strong> Verursacht massives Rauschen (-40 dBm).</p><p class=\"mb-0\"><strong>Booster:</strong> Verstärkt das Signal lokal um satte +15 dBm.</p></div></div></div></div><script>(function() { const wall = document.getElementById('wall'); const line = document.getElementById('sig-line'); const sandbox = document.getElementById('sandbox'); let pairedWith = null; let activeDragging = null; let offset = { x: 0, y: 0 }; const scaleFactor = 32; const materials = { none: { name: '', damp: 0, hide: true }, wood: { name: 'HOLZ', damp: 15, bg: \"repeating-linear-gradient(45deg, #78350f, #78350f 10px, #92400e 10px, #92400e 20px)\" }, concrete: { name: 'BETON', damp: 35, bg: \"#64748b\" }, metal: { name: 'METALL', damp: 85, bg: \"linear-gradient(90deg, #1e293b, #94a3b8, #1e293b)\" } }; window.updateWallStyle = () => { const m = materials[document.getElementById('wall-material').value]; if (m.hide) { wall.style.display = 'none'; } else { wall.style.display = 'block'; wall.style.background = m.bg; document.getElementById('wall-label').innerText = m.name; } updateSim(); }; window.setPairing = (val) => { pairedWith = (val === 'null') ? null : val; line.setAttribute('opacity', pairedWith ? '1' : '0'); updateSim(); }; document.querySelectorAll('.draggable-node').forEach(node => { node.onmousedown = (e) => { activeDragging = node; const rect = node.getBoundingClientRect(); offset.x = e.clientX - rect.left; offset.y = e.clientY - rect.top; }; }); window.onmousemove = (e) => { if (!activeDragging) return; const sRect = sandbox.getBoundingClientRect(); let x = e.clientX - sRect.left - offset.x; let y = e.clientY - sRect.top - offset.y; x = Math.max(0, Math.min(x, sandbox.offsetWidth - activeDragging.offsetWidth)); y = Math.max(0, Math.min(y, sandbox.offsetHeight - activeDragging.offsetHeight)); activeDragging.style.left = x + 'px'; activeDragging.style.top = y + 'px'; updateSim(); }; window.onmouseup = () => activeDragging = null; function updateSim() { const phone = document.getElementById('phone'); const bt = document.getElementById('node-bt'); const nfc = document.getElementById('node-nfc'); const jammer = document.getElementById('node-jammer'); const booster = document.getElementById('node-booster'); const getC = (el) => ({ x: parseInt(el.style.left) || 0, y: parseInt(el.style.top) || 0 }); const pC = getC(phone); const btC = getC(bt); const nfcC = getC(nfc); const dBT = (Math.sqrt(Math.pow(pC.x - btC.x, 2) + Math.pow(pC.y - btC.y, 2)) / scaleFactor).toFixed(1); const dNFC = (Math.sqrt(Math.pow(pC.x - nfcC.x, 2) + Math.pow(pC.y - nfcC.y, 2)) / scaleFactor).toFixed(1); document.getElementById('bt-dist').innerText = dBT + 'm'; document.getElementById('nfc-dist').innerText = dNFC + 'm'; let target = pairedWith === 'bt' ? bt : (pairedWith === 'nfc' ? nfc : null); if (target) { const tC = getC(target); line.setAttribute('x1', pC.x + 25); line.setAttribute('y1', pC.y + 40); line.setAttribute('x2', tC.x + 30); line.setAttribute('y2', tC.y + 15); if (pairedWith === 'bt') { let blocked = false; if (wall.style.display !== 'none') { const wX = parseInt(wall.style.left); const wY = parseInt(wall.style.top); if (((pC.x < wX && tC.x > wX) || (pC.x > wX && tC.x < wX)) && (pC.y + 40 > wY && pC.y < wY + 180)) blocked = true; } const env = parseFloat(document.getElementById('env-select').value); const matDamp = materials[document.getElementById('wall-material').value].damp || 0; let base = (document.getElementById('bt-version').value === '4.0') ? -45 : -35; const distToJam = Math.sqrt(Math.pow(pC.x - getC(jammer).x, 2) + Math.pow(pC.y - getC(jammer).y, 2)) / scaleFactor; const distToBoo = Math.sqrt(Math.pow(pC.x - getC(booster).x, 2) + Math.pow(pC.y - getC(booster).y, 2)) / scaleFactor; let rssi = Math.round(base - (dBT * (3 / env)) - (blocked ? matDamp : 0) + (distToJam < 2.5 ? -40 : 0) + (distToBoo < 2.5 ? 15 : 0)); document.getElementById('p-label').innerText = 'BT LINK'; document.getElementById('p-val').innerText = rssi + ' dBm'; line.setAttribute('stroke', rssi > -70 ? '#198754' : (rssi > -90 ? '#ffc107' : '#dc3545')); } else { let ok = dNFC < 1.0; document.getElementById('p-label').innerText = 'NFC'; document.getElementById('p-val').innerText = ok ? 'TAG OK' : 'ZU WEIT'; line.setAttribute('stroke', ok ? '#198754' : '#dc3545'); } } else { document.getElementById('p-label').innerText = 'IDLE'; document.getElementById('p-val').innerText = ''; } } updateWallStyle(); })();<\/script>"
  },
  "signaltool": {
