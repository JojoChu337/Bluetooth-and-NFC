rt(Math.pow(pC.x - nfcC.x, 2) + Math.pow(pC.y - nfcC.y, 2)) / scaleFactor).toFixed(1); document.getElementById('bt-dist').innerText = dBT + 'm'; document.getElementById('nfc-dist').innerText = dNFC + 'm'; let target = pairedWith === 'bt' ? bt : (pairedWith === 'nfc' ? nfc : null); if (target) { const tC = getC(target); line.setAttribute('x1', pC.x + 25); line.setAttribute('y1', pC.y + 40); line.setAttribute('x2', tC.x + 30); line.setAttribute('y2', tC.y + 15); if (pairedWith === 'bt') { let blocked = false; if (wall.style.display !== 'none') { const wX = parseInt(wall.style.left); const wY = parseInt(wall.style.top); if (((pC.x < wX && tC.x > wX) || (pC.x > wX && tC.x < wX)) && (pC.y + 40 > wY && pC.y < wY + 180)) blocked = true; } const env = parseFloat(document.getElementById('env-select').value); const matDamp = materials[document.getElementById('wall-material').value].damp || 0; let base = (document.getElementById('bt-version').value === '4.0') ? -45 : -35; const distToJam = Math.sqrt(Math.pow(pC.x - getC(jammer).x, 2) + Math.pow(pC.y - getC(jammer).y, 2)) / scaleFactor; const distToBoo = Math.sqrt(Math.pow(pC.x - getC(booster).x, 2) + Math.pow(pC.y - getC(booster).y, 2)) / scaleFactor; let rssi = Math.round(base - (dBT * (3 / env)) - (blocked ? matDamp : 0) + (distToJam < 2.5 ? -40 : 0) + (distToBoo < 2.5 ? 15 : 0)); document.getElementById('p-label').innerText = 'BT LINK'; document.getElementById('p-val').innerText = rssi + ' dBm'; line.setAttribute('stroke', rssi > -70 ? '#198754' : (rssi > -90 ? '#ffc107' : '#dc3545')); } else { let ok = dNFC < 1.0; document.getElementById('p-label').innerText = 'NFC'; document.getElementById('p-val').innerText = ok ? 'TAG OK' : 'ZU WEIT'; line.setAttribute('stroke', ok ? '#198754' : '#dc3545'); } } else { document.getElementById('p-label').innerText = 'IDLE'; document.getElementById('p-val').innerText = ''; } } updateWallStyle(); })();<\/script>"
